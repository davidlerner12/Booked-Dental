{
  "redirects": [
    {
      "source": "/blog",
      "destination": "/en/blog",
      "permanent": true
    },
    {
      "source": "/book",
      "destination": "/en/book",
      "permanent": true
    },
    {
      "source": "/privacy",
      "destination": "/en/privacy",
      "permanent": true
    },
    {
      "source": "/about",
      "destination": "/en/about",
      "permanent": true
    },
    {
      "source": "/en/blog/how-cosmetic-dentists-get-more-consults",
      "destination": "/en/blog/cosmetic-dentists-high-intent-patients",
      "permanent": true
    },
    {
      "source": "/en/blog/how-to-get-more-cosmetic-consults-fast",
      "destination": "/en/blog/cosmetic-dentistry-patient-acquisition-fast",
      "permanent": true
    },
    {
      "source": "/en/blog/generate-consultation-calls-for-dentists",
      "destination": "/en/blog/dental-lead-filtering-for-dentists",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*\\.(?:png|jpg|jpeg|webp|avif|svg|ico|woff2|woff))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/(.*\\.(?:js|css))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(?!@vite|src/|@react-refresh|node_modules/)(.*)",
      "dest": "/index.html"
    }
  ]
}
